{
  "name": "@rtrentjones/greenlight-verify",
  "version": "0.2.27",
  "private": true,
  "description": "Greenlight verify harness (api | mcp | playwright | test | agent-web | eval).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RTrentJones/greenlight.git",
    "directory": "packages/verify"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@rtrentjones/greenlight-shared": "workspace:*"
  },
  "optionalDependencies": {
    "playwright": "^1.49.0",
    "@anthropic-ai/sdk": "^0.69.0"
  }
}
