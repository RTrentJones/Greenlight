{
  "name": "@rtrentjones/greenlight-shared",
  "version": "0.2.4",
  "private": true,
  "description": "Greenlight manifest schema, defineConfig, types, and loader.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RTrentJones/greenlight.git",
    "directory": "packages/shared"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "jiti": "^2.4.2",
    "zod": "^3.24.1"
  }
}
