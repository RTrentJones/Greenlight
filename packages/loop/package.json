{
  "name": "@rtrentjones/greenlight-loop",
  "version": "0.7.0",
  "private": true,
  "description": "The deploy -> verify -> promote loop orchestration + promote guard.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RTrentJones/greenlight.git",
    "directory": "packages/loop"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@rtrentjones/greenlight-adapters": "workspace:*",
    "@rtrentjones/greenlight-shared": "workspace:*",
    "@rtrentjones/greenlight-verify": "workspace:*"
  }
}
