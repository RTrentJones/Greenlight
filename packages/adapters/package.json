{
  "name": "@rtrentjones/greenlight-adapters",
  "version": "0.3.0",
  "private": true,
  "description": "Deploy-target adapters (workers | vercel | oci).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RTrentJones/greenlight.git",
    "directory": "packages/adapters"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@rtrentjones/greenlight-shared": "workspace:*"
  }
}
