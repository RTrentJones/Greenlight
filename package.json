{
  "name": "greenlight",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run typecheck",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-seam": "tsx scripts/check-seam.ts",
    "check-boundaries": "depcruise cli packages --config .dependency-cruiser.cjs",
    "greenlight": "tsx cli/src/bin.ts",
    "check-all": "pnpm build && pnpm lint && pnpm test && pnpm check-seam && pnpm check-boundaries",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "dependency-cruiser": "^16.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  }
}
